GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Telegram (Optional)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=@your_channel_name

# WhatsApp WAHA (Optional)
WAHA_API_URL=http://localhost:3000
WAHA_SESSION=default
WAHA_API_KEY=optional_waha_key

# Webhooks (Optional)
WEBHOOK_URL=https://your-webhook-endpoint.com/publish
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/URL

# OpenAI / DALL-E for media (Optional)
OPENAI_API_KEY=your_openai_api_key_here
